# Copy to .env and adjust if you like. None of these are required — devices are
# discovered and configured from the frontend (Settings -> Scan for devices).

# How often (seconds) to poll each device.
SA_POLL_INTERVAL=2.0

# Backend log level: DEBUG | INFO | WARNING | ERROR
SA_LOG_LEVEL=INFO

# Optional PostgreSQL energy-history storage. DATABASE_URL takes precedence.
# If neither form is configured, the backend keeps using local SQLite.
# DATABASE_URL=postgresql://solar:change-me@postgres:5432/solar_assistant
# SA_DB_HOST=postgres
# SA_DB_PORT=5432
# SA_DB_NAME=solar_assistant
# SA_DB_USER=solar
# SA_DB_PASSWORD=change-me
